# ------------------------------------------------------------------------------
# Ignore everything by default
# ------------------------------------------------------------------------------
/*

# ------------------------------------------------------------------------------
# Repository metadata
# ------------------------------------------------------------------------------
!.gitignore
!/.github/
!/.github/**

# ------------------------------------------------------------------------------
# Local Docker scaffold
# ------------------------------------------------------------------------------
!/docker/
!/docker/**
!/docker-compose.yml
!/.env.example

# ------------------------------------------------------------------------------
# wp-content application tree
# ------------------------------------------------------------------------------
!/wp-content/
!/wp-content/index.php

# ------------------------------------------------------------------------------
# Themes
# ------------------------------------------------------------------------------
!/wp-content/themes/
!/wp-content/themes/**

# ------------------------------------------------------------------------------
# Plugins
# Track all plugins
# ------------------------------------------------------------------------------
!/wp-content/plugins/
!/wp-content/plugins/**

# ------------------------------------------------------------------------------
# MU Plugins
# ------------------------------------------------------------------------------
!/wp-content/mu-plugins/
!/wp-content/mu-plugins/**

# ------------------------------------------------------------------------------
# Uploads (not version controlled)
# ------------------------------------------------------------------------------
/wp-content/uploads/
/uploads/

# ------------------------------------------------------------------------------
# Local database exports/imports (not version controlled)
# ------------------------------------------------------------------------------
/database/

# ------------------------------------------------------------------------------
# Languages
# ------------------------------------------------------------------------------
/wp-content/languages/
/languages/

# ------------------------------------------------------------------------------
# LiteSpeed
# ------------------------------------------------------------------------------
/wp-content/litespeed/
/litespeed/
/.litespeed_conf.dat
/wp-content/object-cache.php
/object-cache.php

# ------------------------------------------------------------------------------
# Defender
# ------------------------------------------------------------------------------
/wp-content/.defender-security-quarantine/
/.defender-security-quarantine/
/wp-content/wp-defender-secrets.php
/wp-defender-secrets.php

# ------------------------------------------------------------------------------
# Maintenance
# ------------------------------------------------------------------------------
/wp-content/maintenance/
/maintenance/
/wp-content/maintenance.php
/maintenance.php

# ------------------------------------------------------------------------------
# Logs
# ------------------------------------------------------------------------------
*.log
/wp-content/post-smtp-migration.log
/post-smtp-migration.log

# ------------------------------------------------------------------------------
# Backup & Temporary files
# ------------------------------------------------------------------------------
*.sql
*.sql.gz
*.zip
*.tar
*.tar.gz
*.gz
*.bak
*.backup

/upgrade/
/upgrade-temp-backup/
/wp-content/upgrade/
/wp-content/upgrade-temp-backup/
/wp-content/snapshot-backups/
/snapshot-backups/

# ------------------------------------------------------------------------------
# macOS / Windows
# ------------------------------------------------------------------------------
.DS_Store
Thumbs.db

# ------------------------------------------------------------------------------
# Project documentation
# ------------------------------------------------------------------------------
!/README.md
!/PROJECT.md
!/AGENTS.md
!/docs/
!/docs/**
