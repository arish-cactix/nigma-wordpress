# ------------------------------------------------------------------------------
# Ignore everything by default
# ------------------------------------------------------------------------------
/*

# ------------------------------------------------------------------------------
# Repository metadata
# ------------------------------------------------------------------------------
!.gitignore

# ------------------------------------------------------------------------------
# Root wp-content files
# ------------------------------------------------------------------------------
!/index.php

# ------------------------------------------------------------------------------
# Themes
# ------------------------------------------------------------------------------
!/themes/
/themes/*

!/themes/index.php

!/themes/Avada/
!/themes/Avada/**

!/themes/Avada-Child-Theme/
!/themes/Avada-Child-Theme/**

# ------------------------------------------------------------------------------
# Plugins
# Track all plugins
# ------------------------------------------------------------------------------
!/plugins/
/plugins/*

!/plugins/index.php
!/plugins/**

# ------------------------------------------------------------------------------
# MU Plugins
# ------------------------------------------------------------------------------
!/mu-plugins/
!/mu-plugins/**

# ------------------------------------------------------------------------------
# Uploads (not version controlled)
# ------------------------------------------------------------------------------
/uploads/

# ------------------------------------------------------------------------------
# Languages
# ------------------------------------------------------------------------------
/languages/

# ------------------------------------------------------------------------------
# LiteSpeed
# ------------------------------------------------------------------------------
/litespeed/
/.litespeed_conf.dat
/object-cache.php

# ------------------------------------------------------------------------------
# Defender
# ------------------------------------------------------------------------------
/.defender-security-quarantine/
/wp-defender-secrets.php

# ------------------------------------------------------------------------------
# Maintenance
# ------------------------------------------------------------------------------
/maintenance/
/maintenance.php

# ------------------------------------------------------------------------------
# Logs
# ------------------------------------------------------------------------------
*.log
/post-smtp-migration.log

# ------------------------------------------------------------------------------
# Backup & Temporary files
# ------------------------------------------------------------------------------
*.sql
*.sql.gz
*.zip
*.tar
*.tar.gz
*.gz
*.bak
*.backup

/upgrade/
/upgrade-temp-backup/
/snapshot-backups/

# ------------------------------------------------------------------------------
# macOS / Windows
# ------------------------------------------------------------------------------
.DS_Store
Thumbs.db

# ------------------------------------------------------------------------------
# Project documentation
# ------------------------------------------------------------------------------
!/README.md
!/PROJECT.md
!/AGENTS.md
!/docs/
!/docs/**
