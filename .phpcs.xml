<?xml version="1.0"?>
<ruleset name="NIGMA WordPress Standards">
    <description>PHPCS configuration for NIGMA WordPress project.</description>

    <!-- Scan our custom code only — explicit files to avoid scanning third-party mu-plugins -->
    <file>wp-content/mu-plugins/security-headers-csp.php</file>
    <file>wp-content/themes/Avada-Child-Theme</file>

    <!-- PHP files only — CSS/JS linting is out of scope -->
    <arg name="extensions" value="php"/>

    <!-- Exclude theme templates — they contain HTML with inline GTM/analytics scripts -->
    <exclude-pattern>*/header.php</exclude-pattern>
    <exclude-pattern>*/footer.php</exclude-pattern>
    <exclude-pattern>*/templates/*</exclude-pattern>

    <!-- Exclude compiled/vendor assets -->
    <exclude-pattern>*/assets/*</exclude-pattern>
    <exclude-pattern>*/vendor/*</exclude-pattern>

    <!-- WordPress Coding Standards -->
    <rule ref="WordPress"/>

    <!-- Target environment -->
    <config name="minimum_supported_wp_version" value="6.0"/>
    <config name="testVersion" value="8.0-"/>
</ruleset>
